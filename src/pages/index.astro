---
import Section from "../components/common/Section.astro";
import FeaturedArticles from "../components/home/FeaturedArticles.astro";
import FeaturedProjects from "../components/home/FeaturedProjects.astro";
import Hero from "../components/home/Hero.astro";
import Layout from "../layouts/Layout.astro";
import { getConfigurationCollection, getOptionalCollection } from "../lib/utils";

const { data: config } = await getConfigurationCollection();

const featuredProjects = (
	await getOptionalCollection("project", (e) => e.data.featured)
).map((e) => ({
	...e.data,
  url: `/projets/${e.data.slug}`,
}));
const featuredArticles = (
	await getOptionalCollection("blog", (e) => e.data.featured)
)
	.sort((a, b) => b.data.timestamp.valueOf() - a.data.timestamp.valueOf())
	.slice(0, 3)
	.map((e) => ({
		...e.data,
    url: `/blog/${e.data.slug}`,
	}));
---

<Layout>
  <Fragment slot="head">
    <title>{config.globalMeta.title}</title>
    <meta
      name="description"
      content={config.globalMeta.longDescription ?? config.globalMeta.description}
    />
    <meta property="og:title" content={config.globalMeta.title} />
    <meta
      property="og:description"
      content={config.globalMeta.description}
    />
    {config.globalMeta.keywords && (
      <meta name="keywords" content={config.globalMeta.keywords.join(", ")} />
    )}
    {config.globalMeta.cardImage && (
      <meta property="og:image" content={config.globalMeta.cardImage} />
    )}
    <meta property="og:url" content={config.site.baseUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={config.globalMeta.title} />
    <meta
      name="twitter:description"
      content={config.globalMeta.description}
    />
    {config.globalMeta.cardImage && (
      <meta name="twitter:image" content={config.globalMeta.cardImage} />
    )}
    <meta http-equiv="content-language" content="fr" />
    <meta name="language" content="French" />
    <link rel="canonical" href={config.site.baseUrl} />
  </Fragment>
  <Section class="my-16">
    <Hero />
  </Section>
  <Section>
    <FeaturedProjects featuredProjects={featuredProjects} />
  </Section>
  <Section>
    <FeaturedArticles featuredArticles={featuredArticles} />
  </Section>
  <Section class="pb-8">
    <div class="border border-current/10 rounded-2xl p-6 sm:p-8 flex flex-col gap-4 bg-black/5 max-w-4xl">
      <div class="flex flex-col gap-2">
        <h2 class="font-display text-2xl sm:text-3xl leading-tight">Lire les bons articles en premier</h2>
        <p class="zag-muted leading-relaxed">
          Si tu débarques sur le blog, commence par la stack web simple, puis les articles sur les assistants de code, puis le tooling Node. Ça donne une vue d’ensemble propre sans te perdre dans le folklore technique.
        </p>
      </div>
      <ul class="grid gap-3 sm:grid-cols-3 text-sm sm:text-base">
        <li><a class="underline underline-offset-4 decoration-current/30 hover:decoration-current" href="/blog/site-propre-rapide-gratuit-2026">La stack simple en 2026</a></li>
        <li><a class="underline underline-offset-4 decoration-current/30 hover:decoration-current" href="/blog/claude-code-cursor-ou-ca-aide-vraiment">Claude Code / Cursor : le vrai gain</a></li>
        <li><a class="underline underline-offset-4 decoration-current/30 hover:decoration-current" href="/blog/pnpm-cest-quoi">Comprendre pnpm rapidement</a></li>
      </ul>
    </div>
  </Section>
</Layout>
