---
import Anchor from "./common/Anchor.astro";

export type Props = {
	title: string;
	description: string;
	url: string;
	githubUrl?: string;
	liveUrl?: string;
	tags: string[];
};

const { title, description, url, githubUrl, liveUrl, tags } = Astro.props;
---

<div class="relative flex flex-col gap-4 mb-10 border-b pb-8 zag-border hover-zag-dotted-grid">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <Anchor url={url} class="text-xl sm:text-2xl">
      {title}
    </Anchor>
    <div class="flex gap-3 text-sm sm:text-base">
      {
        githubUrl ? (
          <Anchor url={githubUrl} class="text-base" external>
            GitHub
          </Anchor>
        ) : null
      }
      {
        liveUrl ? (
          <Anchor url={liveUrl} class="text-base" external>
            Site
          </Anchor>
        ) : null
      }
    </div>
  </div>
  <p class="max-w-3xl zag-text zag-transition text-base leading-7">
    {description}
  </p>
  <div class="flex flex-row flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="-zag-text -zag-bg zag-transition px-2 py-1 text-sm font-semibold">
          {tag}
        </span>
      ))
    }
  </div>
</div>
