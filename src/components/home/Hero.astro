---
import { getConfigurationCollection } from "../../lib/utils";

const { data: config } = await getConfigurationCollection();
---

<div class="flex flex-col gap-8 sm:gap-10">
  <div>
    <h1
      class="text-3xl sm:text-5xl font-display font-semibold opsz leading-tight"
    >
      {config.hero.title}
    </h1>
    <h2
      class="mt-4 text-lg sm:text-2xl font-mono font-medium leading-relaxed opacity-90"
    >
      <p set:html={config.hero.subtitle} />
    </h2>
  </div>

  <p class="max-w-2xl text-base sm:text-lg leading-8 zag-text zag-transition">
    {config.globalMeta.longDescription}
  </p>

  <div>
    <a
      href={config.hero.ctaUrl}
      class="inline-flex items-center gap-2 border px-5 py-3 text-sm sm:text-base font-medium zag-border zag-transition hover:translate-x-1"
    >
      {config.hero.ctaText}
      <span aria-hidden="true">→</span>
    </a>
  </div>
</div>
